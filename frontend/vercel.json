{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "installCommand": "npm install",
  "framework": "vite",
  "env": {
    "VITE_BACKEND_URL": "https://auction-backend-l24v.onrender.com",
    "VITE_BACKEND_PORT": "443",
    "NODE_VERSION": "18"
  },
  "build": {
    "env": {
      "VITE_BACKEND_URL": "https://auction-backend-l24v.onrender.com",
      "VITE_BACKEND_PORT": "443",
      "NODE_VERSION": "18"
    }
  },
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "headers": [
    {
      "source": "/assets/(.*)",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ]
}